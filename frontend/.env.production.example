# Production Environment Configuration
# Copy this file to .env.production and fill in your actual values

# API Configuration
VITE_API_BASE_URL=https://api.your-domain.com
VITE_WS_URL=https://api.your-domain.com

# Application Configuration
VITE_APP_NAME=IBM Cloud Cost Tracker
VITE_APP_VERSION=1.0.0

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_ERROR_REPORTING=true

# API Timeouts (milliseconds)
VITE_API_TIMEOUT=60000
VITE_WS_TIMEOUT=30000

# Cache Configuration
VITE_CACHE_ENABLED=true
VITE_CACHE_TTL=300000

# Export Configuration
VITE_MAX_EXPORT_SIZE=10485760
VITE_EXPORT_QUALITY=0.95

# Pagination
VITE_DEFAULT_PAGE_SIZE=25
VITE_MAX_PAGE_SIZE=100

# Chart Configuration
VITE_CHART_ANIMATION_DURATION=300
VITE_CHART_DEFAULT_HEIGHT=400

# Date Range Limits
VITE_MAX_DATE_RANGE_MONTHS=12
VITE_DEFAULT_DATE_RANGE_MONTHS=1