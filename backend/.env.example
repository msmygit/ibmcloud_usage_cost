# Server Configuration
NODE_ENV=development
PORT=3000
HOST=localhost

# IBM Cloud Authentication
# REQUIRED: IBM Cloud API Key for authentication
# Get your API key from: https://cloud.ibm.com/iam/apikeys
IBM_CLOUD_API_KEY=your_ibm_cloud_api_key_here

# OPTIONAL: Default account ID to pre-select in the UI
# If not provided, the first accessible account will be selected
IBM_CLOUD_ACCOUNT_ID=your_account_id_here

# IBM Cloud API Configuration
IBM_CLOUD_RESOURCE_CONTROLLER_URL=https://resource-controller.cloud.ibm.com
IBM_CLOUD_USAGE_REPORTS_URL=https://billing.cloud.ibm.com

# Caching Configuration
CACHE_ENABLED=true
CACHE_TTL_RESOURCES=3600
CACHE_TTL_USAGE=1800
CACHE_TTL_REPORTS=600
CACHE_MAX_KEYS=1000

# Redis Configuration (Optional)
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# File Cache Configuration
FILE_CACHE_ENABLED=true
FILE_CACHE_DIR=./.file-cache

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Concurrency Configuration
MAX_CONCURRENT_REQUESTS=10
REQUEST_TIMEOUT_MS=30000
REQUEST_RETRY_ATTEMPTS=3
REQUEST_RETRY_DELAY_MS=1000

# Logging Configuration
LOG_LEVEL=info
LOG_PRETTY=true

# CORS Configuration
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# WebSocket Configuration
WEBSOCKET_ENABLED=true
WEBSOCKET_PATH=/socket.io

# Security
API_KEY_HEADER=x-api-key
SESSION_SECRET=your_session_secret_here

# Performance
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6

# Bull Queue (Optional)
BULL_REDIS_HOST=localhost
BULL_REDIS_PORT=6379
BULL_REDIS_PASSWORD=