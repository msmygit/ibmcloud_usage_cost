{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "description": "IBM Cloud Cost Tracking System - Backend API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@ibm-cloud/platform-services": "^0.50.0",
    "ibm-cloud-sdk-core": "^4.3.0",
    "express": "^4.18.2",
    "socket.io": "^4.6.0",
    "bull": "^4.11.5",
    "zod": "^3.22.4",
    "date-fns": "^2.30.0",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "node-cache": "^5.1.2",
    "ioredis": "^5.3.2",
    "p-limit": "^5.0.0",
    "p-retry": "^6.1.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "express-rate-limit": "^7.1.5",
    "compression": "^1.7.4",
    "jspdf": "^2.5.1",
    "xlsx": "^0.18.5",
    "pptxgenjs": "^3.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/cors": "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/bull": "^4.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "tsx": "^4.6.2",
    "nodemon": "^3.0.2",
    "typescript": "^5.3.2",
    "tsc-alias": "^1.8.8",
    "vitest": "^1.0.4",
    "@vitest/ui": "^1.0.4",
    "@vitest/coverage-v8": "^1.0.4"
  }
}